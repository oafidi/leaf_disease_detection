# Copier ce fichier en .env et remplir les valeurs réelles
# cp .env.example .env

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=applescan_auth
MYSQL_USER=apple_user
MYSQL_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
